{
  "name": "consilium",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "tsc --build",
    "rebuild": "tsc --build --clean && tsc --build",
    "clean": "tsc --build --clean",
    "test": "npm run build && node --test test/**/*.test.mjs"
  },
  "devDependencies": {
    "typescript": "^5.8.0"
  }
}
